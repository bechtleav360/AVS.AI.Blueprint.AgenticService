{
    "model": "default",
    "tools": [
        {
            "type": "function",
            "function": {
                "name": "analyze_resource",
                "description": "Analyze a resource for compliance indicators and return structured findings.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "id": {
                            "type": "string",
                            "description": "Unique resource identifier"
                        },
                        "tags": {
                            "type": "object",
                            "description": "Flat key/value tags used for classification",
                            "additionalProperties": {
                                "type": "string"
                            }
                        },
                        "properties": {
                            "type": "object",
                            "description": "Additional resource properties",
                            "additionalProperties": true
                        },
                        "attributes": {
                            "type": "object",
                            "description": "Resource attributes relevant for scoring",
                            "additionalProperties": true
                        }
                    },
                    "required": [
                        "id",
                        "tags",
                        "properties",
                        "attributes"
                    ],
                    "additionalProperties": false
                }
            }
        }
    ],
    "tool_choice": {
        "type": "function",
        "function": {
            "name": "analyze_resource"
        }
    },
    "messages": [
        {
            "role": "system",
            "content": "You must call analyze_resource exactly once using the provided resource payload. Return nothing else."
        },
        {
            "role": "user",
            "content": "Call analyze_resource with this resource:\n{\n  \"id\": \"vm-12345\",\n  \"tags\": {\"environment\": \"production\", \"owner\": \"team-platform\"},\n  \"properties\": {\"region\": \"eu-west-1\"},\n  \"attributes\": {\"encryption_enabled\": false, \"public_access\": true, \"backup_enabled\": false}\n}"
        }
    ],
    "temperature": 0,
    "top_p": 0.8,
    "max_tokens": 512,
    "guided_decoding": {
        "json": {
            "type": "array",
            "minItems": 1,
            "maxItems": 1,
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "const": "analyze_resource"
                    },
                    "parameters": {
                        "type": "object",
                        "properties": {
                            "id": {
                                "type": "string"
                            },
                            "tags": {
                                "type": "object",
                                "additionalProperties": {
                                    "type": "string"
                                }
                            },
                            "properties": {
                                "type": "object",
                                "additionalProperties": true
                            },
                            "attributes": {
                                "type": "object",
                                "additionalProperties": true
                            }
                        },
                        "required": [
                            "id",
                            "tags",
                            "properties",
                            "attributes"
                        ],
                        "additionalProperties": false
                    }
                },
                "required": [
                    "name",
                    "parameters"
                ],
                "additionalProperties": false
            }
        }
    }
}
