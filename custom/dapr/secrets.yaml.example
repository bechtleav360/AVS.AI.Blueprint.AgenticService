# Example Kubernetes secrets for Dapr components
# Copy to secrets.yaml and update with your actual values
# DO NOT commit secrets.yaml to version control!

apiVersion: v1
kind: Secret
metadata:
  name: rabbitmq-secret
  namespace: default
type: Opaque
stringData:
  # RabbitMQ connection string
  # Format: amqp://username:password@host:port
  host: "amqp://guest:guest@rabbitmq.default.svc.cluster.local:5672"
  
  # Alternative: individual components
  username: "guest"
  password: "guest"
  hostname: "rabbitmq.default.svc.cluster.local"
  port: "5672"

---
apiVersion: v1
kind: Secret
metadata:
  name: ai-model-secret
  namespace: default
type: Opaque
stringData:
  # OpenAI API key
  openai_api_key: "sk-proj-your-openai-key-here"
  
  # vLLM API key
  vllm_api_key: "your-vllm-key-here"
  vllm_base_url: "https://your-vllm-server.com/v1"
  
  # Anthropic API key
  anthropic_api_key: "sk-ant-your-anthropic-key-here"

---
apiVersion: v1
kind: Secret
metadata:
  name: data-gateway-secret
  namespace: default
type: Opaque
stringData:
  # Data Gateway API credentials
  api_key: "your-gateway-api-key"
  base_url: "https://gateway.prod.example.com"

---
# Example: Create secrets from command line
# 
# kubectl create secret generic rabbitmq-secret \
#   --from-literal=host='amqp://user:pass@rabbitmq:5672' \
#   --from-literal=username='user' \
#   --from-literal=password='pass'
#
# kubectl create secret generic ai-model-secret \
#   --from-literal=openai_api_key='sk-proj-...' \
#   --from-literal=vllm_api_key='...'
#
# kubectl create secret generic data-gateway-secret \
#   --from-literal=api_key='...' \
#   --from-literal=base_url='https://...'

---
# Example: Create secrets from files
#
# kubectl create secret generic rabbitmq-secret \
#   --from-file=host=./rabbitmq-host.txt \
#   --from-file=username=./rabbitmq-user.txt \
#   --from-file=password=./rabbitmq-pass.txt

---
# Example: Using Dapr secret store component
apiVersion: dapr.io/v1alpha1
kind: Component
metadata:
  name: kubernetes-secret-store
spec:
  type: secretstores.kubernetes
  version: v1
  metadata: []
