# Application Configuration
APP_NAME=asset-backup-checker
APP_PORT=8000
ENV_FOR_DYNACONF=development

# Data Gateway Configuration
DATA_GATEWAY_BASE_URL=http://localhost:8001
DATA_GATEWAY_TIMEOUT_S=30
DATA_GATEWAY_API_KEY=your-api-key-here

# Dapr Configuration
DAPR_PUBSUB_NAME=rabbitmq-pubsub
DAPR_HTTP_PORT=3500
DAPR_GRPC_PORT=50001

# RabbitMQ Configuration (for Dapr component)
RABBITMQ_CONNECTION_STRING=amqp://guest:guest@localhost:5672/

# Retry Configuration
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_FACTOR=2
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_S=60

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=asset-backup-checker
OTEL_RESOURCE_ATTRIBUTES=service.name=asset-backup-checker,service.version=0.1.0

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Cache Configuration (for idempotency)
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=10000

# Security
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# AI Agent Configuration
AI_MODEL_PROVIDER=openai
AI_MODEL_NAME=gpt-4
AI_API_KEY=your-ai-api-key-here
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.1
