{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI: custom-service",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "custom.src.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8001",
                "--reload"
            ],
            "jinja": true,
            "justMyCode": false,
            "console": "integratedTerminal",
            "env": {
                "APP_NAME": "agent-service",
                "LOG_LEVEL": "INFO",
                "LOG_FORMAT": "json",
                "DYNACONF_APP_ENVIRONMENT": "development"
            }
        },
        {
            "name": "Pytest: custom/tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "custom/tests"
            ],
            "jinja": true,
            "justMyCode": false,
            "console": "integratedTerminal"
        }
    ]
}
